# Kestrel — environment configuration
# Copy to .env and fill in every value. The bot panics at startup (validate_env) if any
# required variable is missing or left as a placeholder. NEVER commit the filled-in .env.

# ── Operation mode ────────────────────────────────────────────────────────────
# Keep false until contracts are deployed and dry-run validated. Can be toggled live
# from the dashboard once the bot is running.
SUBMISSION_ENABLED=false
# Premium direction requires the premium-capable KestrelArbitrageur to be deployed and
# tested on a fork first. Leave false to run discount-only.
ENABLE_PREMIUM_DIRECTION=false

# ── Node connections ──────────────────────────────────────────────────────────
RETH_IPC_PATH=/var/run/reth/reth.ipc
# Startup fallback only (used if the IPC socket is absent). Must be a real URL, not KEY.
ETH_WS_FALLBACK=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_WS_URL=wss://your-arbitrum-node:8546
GNOSIS_WS_URL=wss://rpc.gnosischain.com/wss

# ── Keys and wallets ──────────────────────────────────────────────────────────
# Bundle-signing key — loaded via secrecy::SecretString, zeroed on drop. Never share.
SEARCHER_PRIVATE_KEY=0x...
# Receives gas refunds; holds gas ETH only, no protocol exposure.
EXECUTOR_ADDRESS=0x...
# Cold wallet that receives arbitrage profit (used by the contracts / deploy scripts).
PROFIT_WALLET=0x...

# ── Deployed contract addresses (per clone) ──────────────────────────────────
ARBITRAGEUR_ADDRESS=0x...
ARBITRAGEUR_SDAI_ADDRESS=0x...
ARBITRAGEUR_FLASHMINT_ADDRESS=0x...
ARB_SUSDE_ARBITRAGEUR=0x...
KESTREL_TIMELOCK_ADDRESS=0x...

# ── Protocol / pool addresses ────────────────────────────────────────────────
# Ethereum mainnet
ETH_SUSDS_ADDRESS=0xa3931d71877C0E7A3148CB7Eb4463524FEc27fbD
CURVE_SUSDS_USDS_POOL=0x...        # VERIFY on-chain before enabling (coins()/decimals())
ETH_SDAI_ADDRESS=0x83F20F44975D03b1b09e64809B757c47f942BEeA
CURVE_SDAI_DAI_POOL=0x...          # VERIFY on-chain before enabling
SKY_PSM_ADDRESS=0x...
DSS_FLASH_ADDRESS=0x...
BALANCER_VAULT=0xBA12222222228d8Ba445958a75a0704d566BF2C8
# Arbitrum
ARB_SUSDE_ADDRESS=0x211Cc4DD073734dA055fbF44a2b4667d5E5fE5d2
ARB_CURVE_SUSDE_POOL=0x...
ARB_UNISWAP_SUSDE_POOL=0x...
# Gnosis — GNO_SXDAI_POOL must be a VERIFIED sDAI/wxDAI pool (the old default was 3pool).
GNO_SXDAI_ADDRESS=0xaf204776c7245bF4147c2612BF6e5972Ee483701
GNO_SXDAI_POOL=0x...

# ── Price / rate ──────────────────────────────────────────────────────────────
ETH_PRICE_USD=3000                 # sanity-checked to be within $100–$100,000
BASE_MIN_SPREAD_BPS=5
SSR_POLL_INTERVAL_BLOCKS=300       # ~hourly live SSR re-poll (mainnet)

# ── Per-strategy profit floors (USD) and gas multipliers ─────────────────────
ETH_SUSDS_MIN_PROFIT_USD=300
ETH_SUSDS_GAS_MULTIPLIER=5.0
ETH_SDAI_MIN_PROFIT_USD=300
ETH_SDAI_GAS_MULTIPLIER=5.0
ETH_FLASHMINT_MIN_PROFIT_USD=1000
ETH_FLASHMINT_GAS_MULTIPLIER=5.0
ETH_FLASHMINT_MIN_TRADE_USD=50000000   # MUST match contract MIN_FLASH_SIZE ($50M)
ARB_SUSDE_MIN_PROFIT_USD=50
ARB_SUSDE_GAS_MULTIPLIER=3.0
GNO_SXDAI_MIN_PROFIT_USD=20
GNO_SXDAI_GAS_MULTIPLIER=3.0

# ── Sizing / search ───────────────────────────────────────────────────────────
MIN_SPREAD_BPS=5
SPECULATIVE_BPS=3
BINARY_SEARCH_MAX_USD=100000000
AAVE_FLASH_FEE_BPS=5
BALANCER_CAPACITY_USD=300000000
MORPHO_CAPACITY_USD=50000000

# ── Gas / fees ────────────────────────────────────────────────────────────────
MAX_PRIORITY_FEE_GWEI=10
DAILY_GAS_LIMIT_ETH=0.5
MULTI_BLOCK_TARGET_COUNT=3
MIN_BUILDER_LANDING_RATE=0.40

# ── Slippage tolerances (bps of the DEX quote) ───────────────────────────────
MIN_SUSDS_OUT_BPS=9990
MIN_PROFIT_OVERRIDE_BPS=9000
MIN_CROSS_VENUE_OUT_BPS=9950

# ── Persistence / runtime ────────────────────────────────────────────────────
STATE_DB_PATH=./kestrel_state.db
REVM_THREAD_POOL_SIZE=            # blank → num_cpus
GAS_LIMIT_ARB=400000
RUST_LOG=kestrel=info,warn

# ── Builder endpoints (override defaults only if needed) ─────────────────────
# BUILDER_FLASHBOTS=https://relay.flashbots.net
# BUILDER_TITAN=https://rpc.titanbuilder.xyz
# BUILDER_BLOXROUTE=https://mev.api.bloxroute.com/v1/services/submit-flashbots-bundles

# ── Contract deployment (used by forge scripts, not the bot) ─────────────────
# DEPLOYER_PRIVATE_KEY=0x...
# OWNER_PRIVATE_KEY=0x...
# CONFIRM_DEPLOY=true
# DAI_ADDRESS=0x6B175474E89094C44Da98b954EedeAC495271d0F
# USDS_ADDRESS=0x...
# SUSDS_ADDRESS=0xa3931d71877C0E7A3148CB7Eb4463524FEc27fbD
# USDE_ADDRESS=0x...
# USDC_ADDRESS=0x...
# AAVE_POOL_ADDRESS=0x...
# SWAP_ROUTER_ADDRESS=0x...
# TIMELOCK_PROPOSER=0x...
# TIMELOCK_CANCELLER=0x...
